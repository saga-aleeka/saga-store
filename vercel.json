{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    },
    "api/cron/nightly-backup.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/nightly-backup",
      "schedule": "0 7 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/cron/nightly-backup", "destination": "/api/cron/nightly-backup" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
